struct TerminalState {
    bool raw;
    bool echo;
    bool canonical;

    int32 inputSpeed;
    int32 outputSpeed;

    [32]uint8 controlChars;
}

struct ConsoleSize {
    int32 rows;
    int32 cols;
}

struct Terminal {
    int32 fd;
    TerminalState saved;
}

extend Terminal {
    fn open(int32 fd) Terminal {
        Terminal t = Terminal { fd: fd, saved: TerminalState { raw: false, echo: false, canonical: false, inputSpeed: 0, outputSpeed: 0, controlChars: [] } };
        t.save();
        ret t;
    }

    fn save(&self) bool {
        ret __lucis_terminal_get_state(self->fd, &self->saved);
    }

    fn restore(&self) bool {
        ret __lucis_terminal_set_state(self->fd, &self->saved);
    }

    fn enterRaw(&self) bool {
        ret __lucis_terminal_enable_raw(self->fd);
    }

    fn leaveRaw(&self) bool {
        ret __lucis_terminal_disable_raw(self->fd);
    }

    fn isTTY(&self) bool {
        ret __lucis_tty_isatty(self->fd);
    }

    fn read(&self, *uint8 buf, usize size) int32 {
        ret __lucis_tty_read(self->fd, buf, size);
    }

    fn write(&self, *uint8 buf, usize size) int32 {
        ret __lucis_tty_write(self->fd, buf, size);
    }

    fn flush(&self) bool {
        ret __lucis_tty_flush_io(self->fd);
    }

    fn flushInput(&self) bool {
        ret __lucis_tty_flush_input(self->fd);
    }

    fn flushOutput(&self) bool {
        ret __lucis_tty_flush_output(self->fd);
    }

    fn clear(&self) bool {
        ret __lucis_console_clear(self->fd);
    }

    fn clearLine(&self) bool {
        ret __lucis_console_clear_line(self->fd);
    }

    fn showCursor(&self) bool {
        ret __lucis_console_show_cursor(self->fd);
    }

    fn hideCursor(&self) bool {
        ret __lucis_console_hide_cursor(self->fd);
    }

    fn moveCursor(&self, int32 row, int32 col) bool {
        ret __lucis_console_move_cursor(self->fd, row, col);
    }

    fn moveUp(&self, int32 count) bool {
        ret __lucis_console_move_up(self->fd, count);
    }

    fn moveDown(&self, int32 count) bool {
        ret __lucis_console_move_down(self->fd, count);
    }

    fn moveLeft(&self, int32 count) bool {
        ret __lucis_console_move_left(self->fd, count);
    }

    fn moveRight(&self, int32 count) bool {
        ret __lucis_console_move_right(self->fd, count);
    }

    fn getConsoleSize(&self, *ConsoleSize cs) bool {
        ret __lucis_console_get_size(self->fd, cs);
    }

    fn enableEcho(&self) bool {
        ret __lucis_terminal_enable_echo(self->fd);
    }

    fn disableEcho(&self) bool {
        ret __lucis_terminal_disable_echo(self->fd);
    }

    fn enableCanonical(&self) bool {
        ret __lucis_terminal_enable_canonical(self->fd);
    }

    fn disableCanonical(&self) bool {
        ret __lucis_terminal_disable_canonical(self->fd);
    }

    fn setInputSpeed(&self, int32 speed) bool {
        ret __lucis_terminal_set_input_speed(self->fd, speed);
    }

    fn setOutputSpeed(&self, int32 speed) bool {
        ret __lucis_terminal_set_output_speed(self->fd, speed);
    }

    fn setNonBlocking(&self) bool {
        ret __lucis_terminal_set_nonblocking(self->fd);
    }

    fn setBlocking(&self, int32 min, int32 time) bool {
        ret __lucis_terminal_set_blocking(self->fd, min, time);
    }

    fn enableFlowControl(&self) bool {
        ret __lucis_terminal_enable_flow_control(self->fd);
    }

    fn disableFlowControl(&self) bool {
        ret __lucis_terminal_disable_flow_control(self->fd);
    }

    fn enableSignals(&self) bool {
        ret __lucis_terminal_enable_signals(self->fd);
    }

    fn disableSignals(&self) bool {
        ret __lucis_terminal_disable_signals(self->fd);
    }

    fn setIntrChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_intr(self->fd, c);
    }

    fn setQuitChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_quit(self->fd, c);
    }

    fn setEraseChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_erase(self->fd, c);
    }

    fn setKillChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_kill(self->fd, c);
    }

    fn setEofChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_eof(self->fd, c);
    }

    fn setSuspChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_susp_char(self->fd, c);
    }

    fn setEolChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_eol(self->fd, c);
    }

    fn setEol2Char(&self, uint8 c) bool {
        ret __lucis_terminal_set_eol2(self->fd, c);
    }

    fn setStartChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_start(self->fd, c);
    }

    fn setStopChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_stop(self->fd, c);
    }

    fn setReprintChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_reprint(self->fd, c);
    }

    fn setWEraseChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_werase(self->fd, c);
    }

    fn setLNextChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_lnext(self->fd, c);
    }

    fn setDiscardChar(&self, uint8 c) bool {
        ret __lucis_terminal_set_discard(self->fd, c);
    }

    // ── Style ──────────────────────────────────────────────────
    fn setStyle(&self, int32 style, bool on) bool {
        ret __lucis_console_set_style(self->fd, style, on);
    }

    fn bold(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[1m");
    }

    fn dim(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[2m");
    }

    fn italic(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[3m");
    }

    fn underline(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[4m");
    }

    fn reverse(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[7m");
    }

    fn strikethrough(&self) bool {
        ret __lucis_console_sgr(self->fd, c"\x1b[9m");
    }

    fn resetStyle(&self) bool {
        ret __lucis_console_reset_attrs(self->fd);
    }

    // ── Color ──────────────────────────────────────────────────
    fn setForeground(&self, int32 color) bool {
        ret __lucis_console_set_fg(self->fd, color);
    }

    fn setBackground(&self, int32 color) bool {
        ret __lucis_console_set_bg(self->fd, color);
    }

    fn setForeground256(&self, int32 color) bool {
        ret __lucis_console_set_fg_256(self->fd, color);
