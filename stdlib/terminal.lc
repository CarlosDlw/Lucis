    }

    // ── Mouse tracking ─────────────────────────────────────────
    fn enableMouse(&self) bool {
        ret __lucis_console_enable_mouse(self->fd, 1000);
    }

    fn enableMouseDrag(&self) bool {
        ret __lucis_console_enable_mouse(self->fd, 1002);
    }

    fn enableMouseMotion(&self) bool {
        ret __lucis_console_enable_mouse(self->fd, 1003);
    }

    fn disableMouse(&self) bool {
        ret __lucis_console_disable_mouse(self->fd);
    }

