// ── Style constants (bitmask) ──────────────────────────────────
const STYLE_BOLD:      int32 = 1;
const STYLE_DIM:       int32 = 2;
const STYLE_ITALIC:    int32 = 4;
const STYLE_UNDERLINE: int32 = 8;
const STYLE_REVERSE:   int32 = 16;
const STYLE_STRIKE:    int32 = 32;

// ── Color constants (ANSI 16-color palette) ────────────────────
const COLOR_BLACK:        int32 = 0;
const COLOR_RED:          int32 = 1;
const COLOR_GREEN:        int32 = 2;
const COLOR_YELLOW:       int32 = 3;
const COLOR_BLUE:         int32 = 4;
const COLOR_MAGENTA:      int32 = 5;
const COLOR_CYAN:         int32 = 6;
const COLOR_WHITE:        int32 = 7;
const COLOR_BRIGHT_BLACK:   int32 = 8;
const COLOR_BRIGHT_RED:     int32 = 9;
const COLOR_BRIGHT_GREEN:   int32 = 10;
const COLOR_BRIGHT_YELLOW:  int32 = 11;
const COLOR_BRIGHT_BLUE:    int32 = 12;
const COLOR_BRIGHT_MAGENTA: int32 = 13;
const COLOR_BRIGHT_CYAN:    int32 = 14;
const COLOR_BRIGHT_WHITE:   int32 = 15;

// ── Style functions ────────────────────────────────────────────
fn setStyle(int32 fd, int32 style, bool on) bool {
    ret __lucis_console_set_style(fd, style, on);
}

fn bold(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[1m");
}

fn dim(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[2m");
}

fn italic(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[3m");
}

fn underline(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[4m");
}

fn reverse(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[7m");
}

fn strikethrough(int32 fd) bool {
    ret __lucis_console_sgr(fd, c"\x1b[9m");
}

fn resetStyle(int32 fd) bool {
    ret __lucis_console_reset_attrs(fd);
}

