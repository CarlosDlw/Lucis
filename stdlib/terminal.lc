#include "_runtime/tty.h"
#include "_runtime/terminal.h"
#include "_runtime/console.h"

// ── File descriptors ──────────────────────────────────────────
const STDIN: int32 = 0;
const STDOUT: int32 = 1;
const STDERR: int32 = 2;

// ── Control character array size ──────────────────────────────
const NCCS: int32 = 32;

// ── Control character indices (POSIX termios c_cc) ────────────
const VINTR:    int32 = 0;   // SIGINT (Ctrl+C)
const VQUIT:    int32 = 1;   // SIGQUIT (Ctrl+\)
const VERASE:   int32 = 2;   // erase (Backspace)
const VKILL:    int32 = 3;   // kill line (Ctrl+U)
const VEOF:     int32 = 4;   // EOF (Ctrl+D)
const VTIME:    int32 = 5;   // inter-character timer
const VMIN:     int32 = 6;   // minimum chars for read
const VSWTC:    int32 = 7;   // switch character
const VSTART:   int32 = 8;   // resume output (Ctrl+Q)
const VSTOP:    int32 = 9;   // pause output (Ctrl+S)
const VSUSP:    int32 = 10;  // suspend (Ctrl+Z)
const VEOL:     int32 = 11;  // alternate EOL
const VREPRINT: int32 = 12;  // reprint line (Ctrl+R)
const VDISCARD: int32 = 13;  // discard output (Ctrl+O)
const VWERASE:  int32 = 14;  // word erase (Ctrl+W)
const VLNEXT:   int32 = 15;  // literal next (Ctrl+V)
const VEOL2:    int32 = 16;  // second alternate EOL

// ── Baud rate constants ───────────────────────────────────────
const B0:      int32 = 0;       // hang up / no baud
const B50:     int32 = 50;
const B75:     int32 = 75;
const B110:    int32 = 110;
const B134:    int32 = 134;
const B150:    int32 = 150;
const B200:    int32 = 200;
const B300:    int32 = 300;
const B600:    int32 = 600;
const B1200:   int32 = 1200;
const B1800:   int32 = 1800;
const B2400:   int32 = 2400;
const B4800:   int32 = 4800;
const B9600:   int32 = 9600;
const B19200:  int32 = 19200;
const B38400:  int32 = 38400;
const B57600:  int32 = 57600;
const B115200: int32 = 115200;
const B230400: int32 = 230400;

// ── TTY queries ───────────────────────────────────────────────
fn isTTY(int32 fd) bool {
    return __lucis_tty_isatty(fd);
}

// ── Raw I/O ───────────────────────────────────────────────────
fn read(int32 fd, *uint8 buf, usize size) int32 {
    return __lucis_tty_read(fd, buf, size);
}

fn write(int32 fd, *uint8 buf, usize size) int32 {
    return __lucis_tty_write(fd, buf, size);
}

// ── Flush ─────────────────────────────────────────────────────
fn flushInput(int32 fd) bool {
    return __lucis_tty_flush_input(fd);
}

fn flushOutput(int32 fd) bool {
    return __lucis_tty_flush_output(fd);
}

fn flush(int32 fd) bool {
    return __lucis_tty_flush_io(fd);
}

// ── Terminal state ────────────────────────────────────────────
fn getState(int32 fd, *TerminalState state) bool {
    return __lucis_terminal_get_state(fd, state);
}

fn setState(int32 fd, *TerminalState state) bool {
    return __lucis_terminal_set_state(fd, state);
}

// ── Mode helpers ──────────────────────────────────────────────
fn enableRaw(int32 fd) bool {
    return __lucis_terminal_enable_raw(fd);
}

fn disableRaw(int32 fd) bool {
    return __lucis_terminal_disable_raw(fd);
}

fn enableEcho(int32 fd) bool {
    return __lucis_terminal_enable_echo(fd);
}

fn disableEcho(int32 fd) bool {
    return __lucis_terminal_disable_echo(fd);
}

fn enableCanonical(int32 fd) bool {
    return __lucis_terminal_enable_canonical(fd);
}

fn disableCanonical(int32 fd) bool {
    return __lucis_terminal_disable_canonical(fd);
}

