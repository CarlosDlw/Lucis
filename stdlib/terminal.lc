    }

    fn leaveAltScreen(&self) bool {
        ret __lucis_console_leave_alt_screen(self->fd);
    }

    // ── Cursor save / restore ──────────────────────────────────
    fn saveCursor(&self) bool {
        ret __lucis_console_save_cursor(self->fd);
    }

    fn restoreCursor(&self) bool {
        ret __lucis_console_restore_cursor(self->fd);
    }

    // ── Insert / delete lines ──────────────────────────────────
