    // ── Scroll region ──────────────────────────────────────────
    fn setScrollRegion(&self, int32 top, int32 bottom) bool {
        ret __lucis_console_set_scroll_region(self->fd, top, bottom);
    }

    fn resetScrollRegion(&self) bool {
