namespace Main;

use std::log::println;

fn testSysCPU() int32 {
    println("[Testing lucis::sys CPU intrinsics...]");

    // cpu_relax — spin-loop hint
    lucis::sys::cpu_relax();
    println("  ✔ cpu_relax");

    // read_cycle_counter — monotonically increasing
    int64 c0 = lucis::sys::read_cycle_counter();
    int64 c1 = lucis::sys::read_cycle_counter();
    if (c1 < c0) {
        println("  FAIL: read_cycle_counter went backwards");
        ret 1;
    }
    println("  ✔ read_cycle_counter (monotonic)");

    // breakpoint — debug trap (skipped if no debugger)
    // lucis::sys::breakpoint(); // uncomment when running under a debugger

    println("  ✔ sys::CPU tests passed");
    ret 0;
}
