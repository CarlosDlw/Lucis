namespace Main;

use std::log::println;
use std::test::{ assertEqual };

enum PResult<V, E> {
    Ok(V),
    Err(E),
}

fn pdiv(int32 a, int32 b) PResult<int32, string> {
    if b == 0 {
        ret PResult<int32, string>::Err("division by zero");
    }
    ret PResult<int32, string>::Ok(a / b);
}

fn pprocess(int32 a, int32 b) PResult<int32, string> {
    auto val = pdiv(a, b)?;
    ret PResult<int32, string>::Ok(val);
}

fn deepProcess(int32 a, int32 b) PResult<int32, string> {
    auto val = pprocess(a, b)?;
    ret PResult<int32, string>::Ok(val);
}

fn testPropagateOperator() int32 {
    println("[Testing error handling: ? propagate operator...]");

    // ── Test 1: ? operator success path (single level) ──
    auto val1 = pprocess(10, 2) catch {
        ret 1;
    };
    assertEqual(val1, 5);

    // ── Test 2: ? operator error path ──
    auto val2 = pprocess(10, 0) catch {
        assertEqual(it, "division by zero");
        ret -1;
    };
    assertEqual(val2, -1);

    // ── Test 3: ? operator success (deep propagation) ──
    auto val3 = deepProcess(20, 4) catch {
        ret 1;
    };
    assertEqual(val3, 5);

    // ── Test 4: ? operator error (deep propagation) ──
    auto val4 = deepProcess(20, 0) catch {
        assertEqual(it, "division by zero");
        ret -1;
    };
    assertEqual(val4, -1);

    println("✔ propagate operator tests passed");
    ret 0;
}
