namespace Main;

use std::log::println;
use std::test::{ assertEqual };
use std::thread::{ Task, Mutex };

extern void lux_mutexFree(*void mtx);

fn concurrencyComputeA() int32 {
    ret 30;
}

fn concurrencyComputeB() int32 {
    ret 70;
}

fn testConcurrencyMutexLock() int32 {
    println("[Testing concurrency: mutex/lock...]");

    Task<int32> t1 = spawn concurrencyComputeA();
    Task<int32> t2 = spawn concurrencyComputeB();

    int32 r1 = await t1;
    int32 r2 = await t2;

    Mutex mtx = Mutex();
    int32 counter = 0;

    lock(mtx) {
        counter += r1 + r2;
    }

    assertEqual(counter, 100);

    // lock should be reentrant across blocks by release-on-exit semantics
    lock(mtx) {
        counter += 1;
    }

    assertEqual(counter, 101);

    lux_mutexFree(mtx as *void);

    println("✔ concurrency mutex/lock tests passed");
    ret 0;
}
