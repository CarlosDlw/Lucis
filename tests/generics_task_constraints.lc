
use std::log::println;
use std::test::{ assertEqual };
use std::thread::Task;

fn gClamp<T: numeric>(T val, T lo, T hi) T {
    ret val < lo ? lo : val > hi ? hi : val;
}

fn gComputeI32(int32 a, int32 b) int32 {
    ret a + b;
}

fn gComputeF64(float64 x, float64 y) float64 {
    ret x + y;
}

fn testGenericsTaskAndConstraints() int32 {
    println("[Testing generics: Task<T> and constraints...]");

    int32 ci1 = gClamp<int32>(5, 1, 10);
    int32 ci2 = gClamp<int32>(-3, 0, 9);
    int32 ci3 = gClamp<int32>(99, 0, 9);

    assertEqual(ci1, 5);
    assertEqual(ci2, 0);
    assertEqual(ci3, 9);

    float64 cf1 = gClamp<float64>(3.5, 1.0, 5.0);
    float64 cf2 = gClamp<float64>(-2.0, 0.0, 1.0);

    assertEqual(cf1, 3.5);
    assertEqual(cf2, 0.0);

    Task<int32> ti = spawn gComputeI32(10, 20);
    int32 ri = await ti;
    assertEqual(ri, 30);

    Task<float64> tf = spawn gComputeF64(1.25, 2.75);
    float64 rf = await tf;
    assertEqual(rf, 4.0);

    println("✔ generics task/constraint tests passed");
    ret 0;
}
