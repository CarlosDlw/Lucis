
use std::log::println;
use std::test::{ assertEqual };

fn testIntTypes() int32 {
    println("[Testing integer types...]");

    int1 x = 1;
    int1 z = 0;

    // Limits and basic identity
    assertEqual(z, 0);
    assertEqual(x, 1);
    assertEqual(sizeof(int1), 1);
    assertEqual(typeof(x), "int1");

    // Arithmetic semantics
    assertEqual(x + z, 1);
    assertEqual(z + x, 1);
    assertEqual(x - z, 1);
    assertEqual(x * x, 1);
    assertEqual(z * x, 0);

    // Comparisons
    assertEqual(x == 1, true);
    assertEqual(z == 0, true);
    assertEqual(x != z, true);
    assertEqual(x > z, true);
    assertEqual(z < x, true);

    // Coercion to wider integer type
    int8 widened = x;
    assertEqual(widened, 1);
    assertEqual(typeof(widened), "int8");

    println("✔ int1 tests passed");

    int8 y = 127;
    int8 n = -128;
    int8 one = 1;
    int8 two = 2;

    // Limits and basic identity
    assertEqual(y, 127);
    assertEqual(n, -128);
    assertEqual(sizeof(int8), 1);
    assertEqual(typeof(y), "int8");

    // Arithmetic semantics
    assertEqual(one + two, 3);
    assertEqual(two - one, 1);
    assertEqual(two * two, 4);
    assertEqual(8 / two, 4);
    assertEqual(7 % two, 1);
    assertEqual(n + one, -127);

    // Comparisons
    assertEqual(y > n, true);
    assertEqual(n < y, true);
    assertEqual(y >= 127, true);
    assertEqual(n <= -128, true);
    assertEqual(y != n, true);

    // Coercion to wider integer type
    int16 widened8 = y;
    assertEqual(widened8, 127);
    assertEqual(typeof(widened8), "int16");

    println("✔ int8 tests passed");

    int16 i16Max = 32767;
    int16 i16Min = -32768;
    int16 i16One = 1;
    int16 i16Two = 2;

    // Limits and basic identity
    assertEqual(i16Max, 32767);
    assertEqual(i16Min, -32768);
    assertEqual(sizeof(int16), 2);
    assertEqual(typeof(i16Max), "int16");

    // Arithmetic semantics
    assertEqual(i16One + i16Two, 3);
    assertEqual(i16Two - i16One, 1);
    assertEqual(i16Two * i16Two, 4);
    assertEqual(10 / i16Two, 5);
    assertEqual(9 % i16Two, 1);
    assertEqual(i16Min + i16One, -32767);

    // Comparisons
    assertEqual(i16Max > i16Min, true);
    assertEqual(i16Min < i16Max, true);
    assertEqual(i16Max >= 32767, true);
    assertEqual(i16Min <= -32768, true);
    assertEqual(i16Max != i16Min, true);

    // Coercion to wider integer type
    int32 widened16 = i16Max;
    assertEqual(widened16, 32767);
    assertEqual(typeof(widened16), "int32");

    println("✔ int16 tests passed");

    int32 i32Max = 2147483647;
    int32 i32Min = -2147483648;
    int32 i32One = 1;
    int32 i32Two = 2;

    // Limits and basic identity
    assertEqual(i32Max, 2147483647);
    assertEqual(i32Min, -2147483648);
    assertEqual(sizeof(int32), 4);
    assertEqual(typeof(i32Max), "int32");

    // Arithmetic semantics
    assertEqual(i32One + i32Two, 3);
    assertEqual(i32Two - i32One, 1);
    assertEqual(i32Two * i32Two, 4);
    assertEqual(20 / i32Two, 10);
    assertEqual(21 % i32Two, 1);
    assertEqual(i32Min + i32One, -2147483647);

    // Comparisons
    assertEqual(i32Max > i32Min, true);
    assertEqual(i32Min < i32Max, true);
    assertEqual(i32Max >= 2147483647, true);
    assertEqual(i32Min <= -2147483648, true);
    assertEqual(i32Max != i32Min, true);

    // Coercion to wider integer type
    int64 widened32 = i32Max;
    assertEqual(widened32, 2147483647);
    assertEqual(typeof(widened32), "int64");

    println("✔ int32 tests passed");

    int64 i64Max = 9223372036854775807;
    int64 i64Min = -9223372036854775808;
    int64 i64One = 1;
    int64 i64Two = 2;

    // Limits and basic identity
    assertEqual(i64Max, 9223372036854775807);
    assertEqual(i64Min, -9223372036854775808);
    assertEqual(sizeof(int64), 8);
    assertEqual(typeof(i64Max), "int64");

    // Arithmetic semantics
    assertEqual(i64One + i64Two, 3);
    assertEqual(i64Two - i64One, 1);
    assertEqual(i64Two * i64Two, 4);
    assertEqual(40 / i64Two, 20);
    assertEqual(41 % i64Two, 1);
    assertEqual(i64Min + i64One, -9223372036854775807);

    // Comparisons
    assertEqual(i64Max > i64Min, true);
    assertEqual(i64Min < i64Max, true);
    assertEqual(i64Max >= 9223372036854775807, true);
    assertEqual(i64Min <= -9223372036854775808, true);
    assertEqual(i64Max != i64Min, true);

    println("✔ int64 tests passed");

    int128 i128A = 1;
    int128 i128B = 2;
    int128 i128Big = 170141183460469231731687303715884105727;

    // Limits and basic identity
    assertEqual(i128A, 1);
    assertEqual(i128B, 2);
    assertEqual(i128Big, 170141183460469231731687303715884105727);
    assertEqual(sizeof(int128), 16);
    assertEqual(typeof(i128Big), "int128");

    // Arithmetic semantics
    assertEqual(i128A + i128B, 3);
    assertEqual(i128B - i128A, 1);
    assertEqual(i128B * i128B, 4);
    assertEqual(80 / i128B, 40);
    assertEqual(81 % i128B, 1);

    // Comparisons
    assertEqual(i128Big > i128B, true);
    assertEqual(i128A < i128Big, true);
    assertEqual(i128Big >= i128Big, true);
    assertEqual(i128A <= i128B, true);
    assertEqual(i128A != i128B, true);

    println("✔ int128 tests passed");

    intinf infA = 1;
    intinf infB = 2;
    intinf infHuge = 340282366920938463463374607431768211455;

    // Basic identity and arithmetic (without assuming fixed size)
    assertEqual(infA, 1);
    assertEqual(infB, 2);
    assertEqual(infHuge, 340282366920938463463374607431768211455);
    assertEqual(typeof(infA), "intinf");
    assertEqual(infA + infB, 3);
    assertEqual(infB - infA, 1);
    assertEqual(infB * infB, 4);
    assertEqual(infHuge > infB, true);
    assertEqual(infA < infHuge, true);

    println("✔ intinf tests passed");

    isize izA = 1;
    isize izB = 2;

    // Platform-sized integer checks (portable)
    assertEqual(typeof(izA), "isize");
    assertEqual(sizeof(isize), sizeof(usize));
    assertEqual(izA + izB, 3);
    assertEqual(izB - izA, 1);
    assertEqual(izB * izB, 4);
    assertEqual(100 / izB, 50);
    assertEqual(101 % izB, 1);
    assertEqual(izB > izA, true);
    assertEqual(izA < izB, true);

    println("✔ isize tests passed");

    ret 0;
}