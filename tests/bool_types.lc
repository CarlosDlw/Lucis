
use std::log::println;
use std::test::{ assertEqual };

fn testBoolTypes() int32 {
    println("[Testing boolean type...]");

    bool t = true;
    bool f = false;

    // Identity and metadata
    assertEqual(t, true);
    assertEqual(f, false);
    assertEqual(sizeof(bool), 1);
    assertEqual(typeof(t), "bool");

    // Logical semantics
    assertEqual(t && t, true);
    assertEqual(t && f, false);
    assertEqual(t || f, true);
    assertEqual(f || f, false);
    assertEqual(!t, false);
    assertEqual(!f, true);

    // Method coverage from docs
    assertEqual(t.toInt(), 1);
    assertEqual(f.toInt(), 0);
    assertEqual(t.toString(), "true");
    assertEqual(f.toString(), "false");
    assertEqual(t.toggle(), false);
    assertEqual(f.toggle(), true);

    println("✔ bool tests passed");
    ret 0;
}
