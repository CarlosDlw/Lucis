namespace Main;

use std::log::println;
use std::test::{ assertEqual };

enum Status {
    Idle,
    Busy,
}

enum Result<V, E> {
    Ok(V),
    Err(E),
}

struct Particle {
    int32 speed;
    Status status;
    bool active;
}

int32 testEnumGenericAndStructField() {
    println("[Testing enums: generic enums and struct fields...]");

    Result<int32, string> ok = Result<int32, string>::Ok(123);
    Result<int32, string> err = Result<int32, string>::Err("division by zero");

    assertEqual(ok is Result<int32, string>::Ok, true);
    assertEqual(err is Result<int32, string>::Err, true);

    int32 okValue = 0;
    if ok is Result<int32, string>::Ok(v) {
        okValue = v;
    }
    assertEqual(okValue, 123);

    string errValue = "";
    if err is Result<int32, string>::Err(message) {
        errValue = message;
    }
    assertEqual(errValue, "division by zero");

    Particle p = Particle { speed: 5, status: Status::Busy, active: true };

    int32 statusCode = 0;
    switch p.status {
        case Status::Idle {
            statusCode = 1;
        }
        case Status::Busy {
            statusCode = 2;
        }
    }

    assertEqual(statusCode, 2);

    println("✔ enum generic/struct tests passed");
    ret 0;
}
