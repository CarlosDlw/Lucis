namespace Main;

use std::log::println;
use std::test::{ assertEqual };

fn testFloatLiteralFormats() int32 {
    println("[Testing float literal formats...]");

    float64 a = 3.14;
    float64 b = .5;
    float64 c = 1e10;
    float64 d = 1.2e-5;

    // Basic parsing and value sanity
    assertEqual(a > 3.0, true);
    assertEqual(a < 4.0, true);
    assertEqual(b, 0.5);
    assertEqual(c, 10000000000.0);
    assertEqual(d > 0.0, true);
    assertEqual(d < 0.001, true);

    // Scientific notation with negative exponent
    float64 tiny = 5e-3;
    assertEqual(tiny, 0.005);

    // Coercion into other float targets from literals
    float32 f32 = 2.5;
    float80 f80 = 2.5;
    float128 f128 = 2.5;
    double dbl = 2.5;

    assertEqual(f32.toInt(), 2);
    assertEqual(f80.toInt(), 2);
    assertEqual(f128.toInt(), 2);
    assertEqual(dbl.toInt(), 2);

    assertEqual(typeof(a), "float64");
    assertEqual(typeof(f32), "float32");
    assertEqual(typeof(f80), "float80");
    assertEqual(typeof(f128), "float128");
    assertEqual(typeof(dbl), "double");

    println("✔ float literal format tests passed");

    ret 0;
}
