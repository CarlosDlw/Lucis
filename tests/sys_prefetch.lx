namespace Main;

use std::log::println;

fn testSysPrefetch() int32 {
    println("[Testing lux::sys prefetch intrinsics...]");

    int32 data = 42;
    // Read prefetch with high locality
    lux::sys::prefetch_read(&data, 3);
    // Write prefetch with no locality
    lux::sys::prefetch_write(&data, 0);
    // Read prefetch with locality 0 (no temporal reuse)
    lux::sys::prefetch_read(&data, 0);

    println("✔ sys::prefetch tests passed");
    ret 0;
}
