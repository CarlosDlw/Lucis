namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testFloatTypes() {
    println("[Testing floating-point types...]");

    float32 f32 = 1.5;
    // Basic identity and metadata
    assertEqual(sizeof(float32), 4);
    assertEqual(typeof(f32), "float32");
    // Arithmetic and comparison semantics
    assertEqual((f32 + 0.5).toInt(), 2);
    assertEqual((f32 * 2.0).toInt(), 3);
    assertEqual(f32 < 2.0, true);
    assertEqual(f32 > 1.0, true);
    println("✔ float32 tests passed");

    float64 f64 = 3.141592653589793;
    // Basic identity and metadata
    assertEqual(sizeof(float64), 8);
    assertEqual(typeof(f64), "float64");
    // Arithmetic and scientific literal format
    float64 sci = 1.0e10;
    assertEqual((f64 + 0.5).toInt(), 3);
    assertEqual((sci / 1.0e9).toInt(), 10);
    assertEqual(f64 > 3.0, true);
    assertEqual(f64 < 4.0, true);
    println("✔ float64 tests passed");

    float80 f80 = 2.5;
    // Basic identity and metadata
    assertEqual(sizeof(float80) == 10 || sizeof(float80) == 16, true);
    assertEqual(typeof(f80), "float80");
    // Arithmetic and comparison semantics
    assertEqual((f80 + 0.5).toInt(), 3);
    assertEqual((f80 * 2.0).toInt(), 5);
    assertEqual(f80 > 2.0, true);
    assertEqual(f80 < 3.0, true);
    println("✔ float80 tests passed");

    float128 f128 = 6.25;
    // Basic identity and metadata
    assertEqual(sizeof(float128), 16);
    assertEqual(typeof(f128), "float128");
    // Arithmetic and comparison semantics
    assertEqual((f128 + 0.75).toInt(), 7);
    assertEqual((f128 / 2.0).toInt(), 3);
    assertEqual(f128 > 6.0, true);
    assertEqual(f128 < 7.0, true);
    println("✔ float128 tests passed");

    double d = 2.718281828459045;
    // Alias metadata and behavior
    assertEqual(sizeof(double), 8);
    assertEqual(typeof(d), "double");
    assertEqual((d + 0.3).toInt(), 3);
    assertEqual(d > 2.0, true);
    assertEqual(d < 3.0, true);
    println("✔ double tests passed");

    ret 0;
}
