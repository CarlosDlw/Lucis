namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testIntMethodsExtra() {
    println("[Testing extra integer methods...]");

    int32 a = -42;
    assertEqual(a.abs(), 42);
    assertEqual(a.sign(), -1);

    int32 n = 15;
    assertEqual(n.clamp(0, 10), 10);
    assertEqual((5).pow(3), 125);
    assertEqual((7).min(9), 7);
    assertEqual((7).max(9), 9);

    int8 w = 127;
    assertEqual(w.wrappingAdd(1), -128);
    assertEqual((0 as int8).wrappingSub(1), -1);
    assertEqual((64 as int8).wrappingMul(2), -128);

    int8 s = 127;
    assertEqual(s.saturatingAdd(1), 127);
    assertEqual(((-128) as int8).saturatingSub(1), -128);

    uint8 bits = 0b00001000;
    assertEqual(bits.leadingZeros(), 4);
    assertEqual(bits.trailingZeros(), 3);
    assertEqual((0b1011 as uint8).countOnes(), 3);

    assertEqual((1 as uint8).rotateLeft(1), 2);
    assertEqual((2 as uint8).rotateRight(1), 1);

    assertEqual((0x1234 as uint16).byteSwap(), 0x3412);
    uint32 v = 123;
    uint32 be = v.toBigEndian();
    uint32 le = v.toLittleEndian();
    assertEqual(be == v || be == v.byteSwap(), true);
    assertEqual(le == v || le == v.byteSwap(), true);

    assertEqual((8 as uint32).isPowerOfTwo(), true);
    assertEqual((9 as uint32).isPowerOfTwo(), false);
    assertEqual((9 as uint32).nextPowerOfTwo(), 16);
    assertEqual((8 as uint32).log2(), 3);

    assertEqual((255 as int32).toStringRadix(16).contains("ff"), true);
    assertEqual((65 as int32).toChar(), 'A');

    println("✔ extra integer method tests passed");
    ret 0;
}
