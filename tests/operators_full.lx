namespace Main;

use std::log::println;
use std::test::{ assertEqual };

struct OpPoint {
    int32 x;
    int32 y;
}

bool opMarkTrue(*int32 counter) {
    *counter += 1;
    ret true;
}

int32 testOperatorsFull() {
    println("[Testing operators full coverage...]");

    // Arithmetic + precedence
    int32 a = 10;
    int32 b = 3;
    assertEqual(a + b, 13);
    assertEqual(a - b, 7);
    assertEqual(a * b, 30);
    assertEqual(a / b, 3);
    assertEqual(a % b, 1);
    assertEqual(-42, -42);
    assertEqual(2 + 3 * 4, 14);
    assertEqual((2 + 3) * 4, 20);

    // Comparison
    assertEqual(10 == 10, true);
    assertEqual(10 != 5, true);
    assertEqual(5 < 10, true);
    assertEqual(10 > 5, true);
    assertEqual(5 <= 5, true);
    assertEqual(10 >= 10, true);

    // Logical + short-circuit
    bool t = true;
    bool f = false;
    assertEqual(!t, false);
    assertEqual(t && f, false);
    assertEqual(t || f, true);

    int32 mark = 0;
    bool andRes = f && opMarkTrue(&mark);
    assertEqual(andRes, false);
    assertEqual(mark, 0);

    bool orRes = t || opMarkTrue(&mark);
    assertEqual(orRes, true);
    assertEqual(mark, 0);

    // Bitwise
    int32 x = 0b1100;
    int32 y = 0b1010;
    assertEqual(x & y, 8);
    assertEqual(x | y, 14);
    assertEqual(x ^ y, 6);
    assertEqual(~0, -1);
    assertEqual(1 << 4, 16);
    assertEqual(64 >> 2, 16);

    int32 hv = 0xFF;
    assertEqual(hv & 0x0F, 15);
    assertEqual(hv | 0x100, 511);
    assertEqual(hv ^ 0xFF, 0);

    // Assignment operators
    int32 z = 10;
    z += 5;
    z -= 3;
    z *= 2;
    z /= 6;
    z %= 3;
    assertEqual(z, 1);

    int32 bits = 1;
    bits <<= 4;
    bits >>= 2;
    assertEqual(bits, 4);

    int32 bb = 0b1111;
    bb &= 0b1010;
    assertEqual(bb, 10);
    bb |= 0b0001;
    assertEqual(bb, 11);
    bb ^= 0b0011;
    assertEqual(bb, 8);

    // Increment / decrement
    int32 n = 5;
    int32 pre = ++n;
    int32 post = n++;
    int32 preDec = --n;
    int32 postDec = n--;
    assertEqual(pre, 6);
    assertEqual(post, 6);
    assertEqual(preDec, 6);
    assertEqual(postDec, 6);
    assertEqual(n, 5);

    // Ternary
    int32 maxV = a > b ? a : b;
    int32 minV = a < b ? a : b;
    int32 cat = 5 > 10 ? 1 : (5 > 3 ? 2 : 3);
    assertEqual(maxV, 10);
    assertEqual(minV, 3);
    assertEqual(cat, 2);

    // Null coalescing (safe fallback path)
    int32 raw = 42;
    *int32 nilPtr = null;
    *int32 ptrFallback = nilPtr ?? &raw;
    assertEqual(*ptrFallback, 42);

    // Type operators
    float64 fx = a as float64;
    int32 trunc = 3.14 as int32;
    assertEqual(fx, 10.0);
    assertEqual(trunc, 3);
    assertEqual(a is int32, true);
    assertEqual(sizeof(int32), 4);
    assertEqual(sizeof(float64), 8);
    assertEqual(typeof(a), "int32");

    // Pointer operators + dot/arrow
    OpPoint p = OpPoint { x: 7, y: 9 };
    *OpPoint pp = &p;
    assertEqual((*pp).x, 7);
    assertEqual(pp->y, 9);

    // Range operators in loops
    int32 ex = 0;
    for int32 i in 0..5 {
        ex += i;
    }
    assertEqual(ex, 10);

    int32 inc = 0;
    for int32 i in 1..=5 {
        inc += i;
    }
    assertEqual(inc, 15);

    println("✔ operators full tests passed");
    ret 0;
}
