namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testControlFlowBreakContinue() {
    println("[Testing control flow: break/continue...]");

    int32 breakSum = 0;
    for int32 i in 0..100 {
        if i == 3 {
            break;
        }
        breakSum += i;
    }
    assertEqual(breakSum, 3);

    int32 continueSum = 0;
    for int32 i in 0..6 {
        if i == 2 {
            continue;
        }
        if i == 4 {
            continue;
        }
        continueSum += i;
    }
    assertEqual(continueSum, 9);

    int32 w = 0;
    int32 whileSum = 0;
    while w < 8 {
        w += 1;
        if w % 2 == 0 {
            continue;
        }
        if w == 7 {
            break;
        }
        whileSum += w;
    }
    assertEqual(w, 7);
    assertEqual(whileSum, 9);

    int32 l = 0;
    int32 loopOddSum = 0;
    loop {
        l += 1;
        if l == 8 {
            break;
        }
        if l % 2 == 0 {
            continue;
        }
        loopOddSum += l;
    }
    assertEqual(loopOddSum, 16);

    println("✔ control flow break/continue tests passed");
    ret 0;
}
