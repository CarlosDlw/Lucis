namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testRangesFull() {
    println("[Testing ranges full coverage...]");

    // Exclusive range: 0..5 => 0,1,2,3,4
    int32 sumExclusive = 0;
    for int32 i in 0..5 {
        sumExclusive += i;
    }
    assertEqual(sumExclusive, 10);

    // Inclusive range: 1..=5 => 1,2,3,4,5
    int32 sumInclusive = 0;
    for int32 i in 1..=5 {
        sumInclusive += i;
    }
    assertEqual(sumInclusive, 15);

    // Precedence: 0..count * 2 => 0..(count*2)
    int32 count = 5;
    int32 sumPrec = 0;
    for int32 i in 0..count * 2 {
        sumPrec += i;
    }
    assertEqual(sumPrec, 45);

    // Countdown alternative with while (as documented)
    int32 w = 5;
    int32 downSum = 0;
    while w > 0 {
        downSum += w;
        w -= 1;
    }
    assertEqual(downSum, 15);

    // List comprehension with exclusive range
    [4]int32 nums = [x | for int32 x in 0..4];
    assertEqual(nums.equals([0, 1, 2, 3]), true);

    // Transform + range
    [4]int32 squares = [x * x | for int32 x in 0..4];
    assertEqual(squares.equals([0, 1, 4, 9]), true);

    // Inclusive range in comprehension
    [5]int32 incl = [x | for int32 x in 1..=5];
    assertEqual(incl.equals([1, 2, 3, 4, 5]), true);

    // Filtered comprehension currently keeps declared size and zero-fills remainder
    [8]int32 evens = [x | for int32 x in 0..8 if x % 2 == 0];
    assertEqual(evens.equals([0, 2, 4, 6, 0, 0, 0, 0]), true);

    println("✔ ranges full tests passed");
    ret 0;
}
