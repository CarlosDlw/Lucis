namespace Main;

use std::log::println;
use std::test::{ assertEqual };

void writeAnswer(*int32 out) {
    *out = 42;
}

void clearValue(*int32 out) {
    *out = 0;
}

int32 testVoidTypes() {
    println("[Testing void type...]");

    int32 value = -1;

    // The function has no return value, so correctness is validated by side effects.
    writeAnswer(&value);
    assertEqual(value, 42);

    clearValue(&value);
    assertEqual(value, 0);

    println("✔ void tests passed");
    ret 0;
}
