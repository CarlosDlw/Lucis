namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testSysBitOps() {
    println("[Testing lux::sys bit manipulation intrinsics...]");

    // ── bitreverse ───────────────────────────────────────────────
    assertEqual(lux::sys::bitreverse<int32>(0x12345678), 0x1E6A2C48);
    assertEqual(lux::sys::bitreverse<int16>(0x1234), 0x2C48);
    assertEqual(lux::sys::bitreverse<int8>(0x78), 0x1E);

    // ── bswap ────────────────────────────────────────────────────
    assertEqual(lux::sys::bswap<int32>(0x12345678), 0x78563412);
    assertEqual(lux::sys::bswap<int64>(0x0102030405060708), 0x0807060504030201);

    // ── ctpop ────────────────────────────────────────────────────
    assertEqual(lux::sys::ctpop<int32>(0x12345678), 13);
    assertEqual(lux::sys::ctpop<int8>(0xFF), 8);
    assertEqual(lux::sys::ctpop<int8>(0x00), 0);

    // ── ctlz ─────────────────────────────────────────────────────
    assertEqual(lux::sys::ctlz<int32>(0x12345678), 3);
    assertEqual(lux::sys::ctlz<int32>(0), 32);
    assertEqual(lux::sys::ctlz<int8>(0x0F), 4);

    // ── cttz ─────────────────────────────────────────────────────
    assertEqual(lux::sys::cttz<int32>(0x12345678), 3);
    assertEqual(lux::sys::cttz<int32>(0), 32);
    assertEqual(lux::sys::cttz<int8>(0x10), 4);

    // ── compose: bswap(bitreverse(x)) == bitreverse(bswap(x)) ────
    int32 x = 0x12345678;
    int32 a = lux::sys::bswap<int32>(lux::sys::bitreverse<int32>(x));
    int32 b = lux::sys::bitreverse<int32>(lux::sys::bswap<int32>(x));
    assertEqual(a, b);

    println("✔ sys::bit ops tests passed");
    ret 0;
}
