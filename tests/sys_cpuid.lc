use std::log::println;
use std::test::{ assertTrue, assertGreater };

fn testSysCpuid() int32 {
    println("[Testing sys:: CPUID intrinsic...]");

    uint32 eax = 0u32;
    uint32 ebx = 0u32;
    uint32 ecx = 0u32;
    uint32 edx = 0u32;

    // Leaf 0: vendor identification + max standard leaf
    lucis::sys::cpuid(0u32, 0u32, &eax, &ebx, &ecx, &edx);

    // Max standard leaf should be at least 1 (every x86 CPU supports leaf 1)
    assertGreater(eax as int32, 0);

    // Vendor string in ebx/ecx/edx should be non-zero
    assertTrue(ebx != 0u32);
    assertTrue(ecx != 0u32);
    assertTrue(edx != 0u32);

    // Leaf 1: feature info
    lucis::sys::cpuid(1u32, 0u32, &eax, &ebx, &ecx, &edx);

    // Feature flags should have some bits set (any modern CPU)
    assertTrue(ecx != 0u32 || edx != 0u32);

    // Sub-leaf test: leaf 7 sub-leaf 0 (extended features)
    lucis::sys::cpuid(7u32, 0u32, &eax, &ebx, &ecx, &edx);

    println("✔ sys::cpuid tests passed");
    ret 0;
}
