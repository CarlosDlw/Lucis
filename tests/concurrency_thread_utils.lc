
use std::log::println;
use std::test::{ assertEqual };
use std::thread::{ cpuCount, threadId, yield };

fn testConcurrencyThreadUtils() int32 {
    println("[Testing concurrency: thread utilities...]");

    uint32 cores = cpuCount();
    assertEqual(cores >= 1, true);

    uint64 tid = threadId();
    assertEqual(tid > 0, true);

    yield();

    println("✔ concurrency thread utility tests passed");
    ret 0;
}
