namespace Main;

use std::log::println;
use std::test::{ assertEqual };

fn testTypeCastingAndChecking() int32 {
    println("[Testing type casting and type checking...]");

    int32 base = 42;

    int64 toInt64 = base as int64;
    uint32 toUint32 = base as uint32;
    int16 toInt16 = base as int16;
    uint8 toUint8 = base as uint8;

    assertEqual(toInt64, 42);
    assertEqual(toUint32, 42);
    assertEqual(toInt16, 42);
    assertEqual(toUint8, 42);

    int32 negOne = -1;
    uint32 wrapped = negOne as uint32;
    assertEqual(typeof(wrapped), "uint32");

    float64 asF64 = base as float64;
    float32 asF32 = base as float32;
    assertEqual(asF64.toInt(), 42);
    assertEqual((asF32 as int32), 42);

    float64 frac = 3.75;
    int32 trunc = frac as int32;
    assertEqual(trunc, 3);

    char a = 'A';
    int32 asciiA = a as int32;
    char b = 66 as char;
    assertEqual(asciiA, 65);
    assertEqual(b, 'B');

    int64 ptrValue = 99;
    *int64 p = &ptrValue;
    *void generic = p as *void;
    *int64 back = generic as *int64;
    assertEqual(*back, 99);

    cstring cstrVal = c"Lux";
    *char asCharPtr = cstrVal as *char;
    cstring asCStringAgain = asCharPtr as cstring;
    assertEqual(fromCStr(asCStringAgain), "Lux");

    assertEqual(base is int32, true);
    assertEqual(toInt64 is int64, true);
    assertEqual(asF64 is float64, true);
    assertEqual(a is char, true);
    assertEqual(p is *int64, true);
    assertEqual(generic is *void, true);

    assertEqual(typeof(base), "int32");
    assertEqual(typeof(toInt64), "int64");
    assertEqual(typeof(asF64), "float64");
    assertEqual(typeof(a), "char");
    assertEqual(typeof(generic), "*void");
    assertEqual(typeof(asCStringAgain), "*char");

    assertEqual(sizeof(bool), 1);
    assertEqual(sizeof(char), 1);
    assertEqual(sizeof(int32), 4);
    assertEqual(sizeof(int64), 8);
    assertEqual(sizeof(float32), 4);
    assertEqual(sizeof(float64), 8);
    assertEqual(sizeof(double), 8);
    assertEqual(sizeof(*void), sizeof(*int64));

    println("✔ type casting and type checking tests passed");
    ret 0;
}