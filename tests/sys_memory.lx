namespace Main;

use std::log::println;
use std::test::{ assertEqual };

fn testSysMemory() int32 {
    println("[Testing lux::sys memory intrinsics...]");

    // ── memcpy ─────────────────────────────────────────────────────
    {
        int32 x = 42;
        int32 y = 0;
        lux::sys::memcpy(&y, &x, 4);
        assertEqual(y, 42);
    }

    // ── memmove (overlapping) ──────────────────────────────────────
    {
        [4]int32 arr = [1, 2, 3, 4];
        lux::sys::memmove(&arr[0], &arr[2], 8);
        assertEqual(arr[0], 3);
        assertEqual(arr[1], 4);
        assertEqual(arr[2], 3);
        assertEqual(arr[3], 4);
    }

    // ── memset ─────────────────────────────────────────────────────
    {
        [4]int32 arr = [-1, -1, -1, -1];
        lux::sys::memset(&arr[0], 0, 16);
        assertEqual(arr[0], 0);
        assertEqual(arr[1], 0);
        assertEqual(arr[2], 0);
        assertEqual(arr[3], 0);
    }

    // ── memset + memcpy compose ────────────────────────────────────
    {
        [2]int64 buf = [0, 0];
        // Zero via memset, then copy via memcpy
        lux::sys::memset(&buf[0], 0, 16);
        int64 val = 12345678901234;
        lux::sys::memcpy(&buf[0], &val, 8);
        assertEqual(buf[0], 12345678901234);
        assertEqual(buf[1], 0);
    }

    println("✔ sys::memory tests passed");
    ret 0;
}
