namespace Main;

use std::log::println;
use std::test::{ assertEqual };

struct SCorePoint {
    int32 x;
    int32 y;
}

struct SCoreVec2 {
    int32 x;
    int32 y;
}

struct SCoreRect {
    SCoreVec2 origin;
    SCoreVec2 size;
}

fn testStructsCore() int32 {
    println("[Testing structs: core/nested/mutation...]");

    SCorePoint p = SCorePoint { x: 10, y: 20 };
    assertEqual(p.x, 10);
    assertEqual(p.y, 20);

    p.x = 99;
    p.y += 1;
    assertEqual(p.x, 99);
    assertEqual(p.y, 21);

    SCoreRect r = SCoreRect {
        origin: SCoreVec2 { x: 0, y: 0 },
        size: SCoreVec2 { x: 100, y: 50 }
    };

    assertEqual(r.origin.x, 0);
    assertEqual(r.origin.y, 0);
    assertEqual(r.size.x, 100);
    assertEqual(r.size.y, 50);

    r.size.x = 120;
    r.origin.y += 7;

    assertEqual(r.size.x, 120);
    assertEqual(r.origin.y, 7);

    println("✔ structs core tests passed");
    ret 0;
}
