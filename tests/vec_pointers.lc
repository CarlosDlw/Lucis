
use std::log::println;
use std::test::{ assertEqual };

fn fillVec<T>(T value, int32 size, *vec<T> v) void {
  for int32 i in size {
    v.push(value);
  }
}

fn assignVec<T>(T value, int32 size, *vec<T> v) void {
  for int32 i in size {
    v[i] = value;
  }
}

fn testVecPointers() int32 {
    println("[Testing vec pointers...]");

    vec<int32> a;
    fillVec<int32>(42, 5, &a);
    assertEqual(a.len(), 5);
    assertEqual(a.at(0 as uint32), 42);
    assertEqual(a.at(4 as uint32), 42);

    vec<int32> b;
    b.push(10);
    b.push(20);
    b.push(30);
    assignVec<int32>(99, 3, &b);
    assertEqual(b.len(), 3);
    assertEqual(b.at(0 as uint32), 99);
    assertEqual(b.at(1 as uint32), 99);
    assertEqual(b.at(2 as uint32), 99);

    println("✔ vec pointer tests passed");
    ret 0;
}
