namespace Main;

use std::log::println;
use std::test::{ assertEqual };

fn controlFlowMayFail(bool fail) int32 {
    if fail {
        throw Error { message: "control flow test error" };
    }
    ret 77;
}

fn testControlFlowErrorHandling() int32 {
    println("[Testing control flow: try/catch/finally...]");

    bool caught = false;
    bool finallyRan = false;
    string msg = "";
    string fileName = "";
    int32 lineNo = 0;
    int32 colNo = 0;

    try {
        int32 v = controlFlowMayFail(true);
        assertEqual(v, 0);
    } catch (Error e) {
        caught = true;
        msg = e.message;
        fileName = e.file;
        lineNo = e.line;
        colNo = e.column;
    } finally {
        finallyRan = true;
    }

    assertEqual(caught, true);
    assertEqual(finallyRan, true);
    assertEqual(msg.contains("control flow test error"), true);
    assertEqual(fileName.len() > 0, true);
    assertEqual(lineNo > 0, true);
    assertEqual(colNo > 0, true);

    bool noThrowCaught = false;
    bool noThrowFinally = false;
    int32 ok = 0;

    try {
        ok = controlFlowMayFail(false);
    } catch (Error e) {
        noThrowCaught = true;
        ok = -1;
    } finally {
        noThrowFinally = true;
    }

    assertEqual(ok, 77);
    assertEqual(noThrowCaught, false);
    assertEqual(noThrowFinally, true);

    println("✔ control flow error-handling tests passed");
    ret 0;
}
