namespace Main;

use std::log::println;
use std::test::{ assertEqual };

int32 testSysFence() {
    println("[Testing lux::sys fence intrinsics...]");

    // ── All 4 fencing levels ────────────────────────────────────
    lux::sys::fence_acquire();
    lux::sys::fence_release();
    lux::sys::fence_acq_rel();
    lux::sys::fence_seq_cst();

    // ── Release / acquire publish pattern ───────────────────────
    int32 flag = 0;
    int32 data = 0;

    // Thread 1 (simulated): publish data with release
    data = 42;
    lux::sys::fence_release();
    flag = 1;

    // Thread 2 (simulated): consume with acquire
    lux::sys::fence_acquire();
    int32 f = flag;
    assertEqual(f, 1);
    // If we saw flag=1, the fence guarantees we also see data=42
    // (single-threaded test validates the fence doesn't corrupt state)
    assertEqual(data, 42);

    println("✔ sys::fence tests passed");
    ret 0;
}
