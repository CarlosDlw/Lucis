{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lucis",
  "scopeName": "source.lucis",
  "fileTypes": ["tm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#c-strings" },
    { "include": "#strings" },
    { "include": "#char-literals" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-operator" },
    { "include": "#keywords-error-handling" },
    { "include": "#primitive-types" },
    { "include": "#builtin-functions" },
    { "include": "#declaration-name" },
    { "include": "#function-call" },
    { "include": "#function-decl" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lucis",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation.lucis",
          "begin": "/\\*\\*(?!\\*)",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.lucis" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.lucis" }
          },
          "patterns": [
            {
              "match": "(@(?:param|property|field))\\s+(\\S+)\\s+(\\S+)",
              "captures": {
                "1": { "name": "storage.type.class.jsdoc.lucis" },
                "2": { "name": "entity.name.type.instance.jsdoc.lucis" },
                "3": { "name": "variable.other.jsdoc.lucis" }
              }
            },
            {
              "match": "(@(?:returns?|type|throws|brief|deprecated|version|author|see|since|todo|example|remarks|note|warning|private|public|protected|internal|struct|namespace|field|property))\\b",
              "name": "storage.type.class.jsdoc.lucis"
            }
          ]
        },
        {
          "name": "comment.block.lucis",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.lucis" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.lucis" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.lucis",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.lucis" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.lucis" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.lucis",
          "match": "\\\\([nrtabfv0\\\\\"'\\x]|x[0-9a-fA-F]{2})"
        }
      ]
    },
    "char-literals": {
      "name": "string.quoted.single.lucis",
      "match": "'(\\\\([nrtabfv0\\\\\"'\\x]|x[0-9a-fA-F]{2})|[^'\\\\\\r\\n])'"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.lucis",
          "match": "\\b([0-9]+\\.[0-9]+|\\.[0-9]+)([eE][+-]?[0-9]+)?\\b|\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.lucis",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lucis",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.lucis",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.language.self.lucis",
          "match": "\\bself\\b"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.system.lucis",
          "match": "(#include)\\s+(<[^>]+>)",
          "captures": {
            "1": { "name": "keyword.control.directive.include.lucis" },
            "2": { "name": "string.quoted.other.include.lucis" }
          }
        },
        {
          "name": "meta.preprocessor.include.local.lucis",
          "match": "(#include)\\s+(\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.control.directive.include.lucis" },
            "2": { "name": "string.quoted.double.include.lucis" }
          }
        }
      ]
    },
    "c-strings": {
      "name": "string.quoted.double.c.lucis",
      "begin": "c\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.c.lucis" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.c.lucis" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.lucis",
          "match": "\\\\([nrtabfv0\\\\\"'\\x]|x[0-9a-fA-F]{2})"
        }
      ]
    },
    "keywords-control": {
      "name": "keyword.control.lucis",
      "match": "\\b(if|else|for|in|loop|while|do|break|continue|switch|case|default|ret|defer)\\b"
    },
    "keywords-declaration": {
      "name": "storage.type.lucis",
      "match": "\\b(namespace|use|struct|union|enum|fn|type|extend|extern)\\b"
    },
    "keywords-operator": {
      "name": "keyword.operator.word.lucis",
      "match": "\\b(as|is|sizeof|typeof|spawn|await|lock)\\b"
    },
    "keywords-error-handling": {
      "name": "keyword.control.error.lucis",
      "match": "\\b(try|catch|finally|throw)\\b"
    },
    "primitive-types": {
      "name": "support.type.primitive.lucis",
      "match": "\\b(int1|int8|int16|int32|int64|int128|intinf|isize|uint1|uint8|uint16|uint32|uint64|uint128|usize|float32|float64|float80|float128|double|bool|char|void|string|cstring)\\b"
    },
    "builtin-functions": {
      "name": "support.function.builtin.lucis",
      "match": "\\b(exit|panic|assert|assertMsg|unreachable|toString|toInt|toFloat|toBool|cstr|fromCStr|fromCStrLen)\\b(?=\\s*\\()"
    },
    "declaration-name": {
      "patterns": [
        {
          "comment": "Struct/union/enum/extend name: struct Foo, enum Bar, extend Baz",
          "match": "\\b(struct|union|enum|extend)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.lucis" },
            "2": { "name": "entity.name.type.lucis" }
          }
        },
        {
          "comment": "Namespace declaration: namespace Foo",
          "match": "\\b(namespace)\\s+([A-Za-z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.lucis" },
            "2": { "name": "entity.name.namespace.lucis" }
          }
        }
      ]
    },
    "function-decl": {
      "comment": "Matches function declarations: typeSpec name( ... ) or fn name(",
      "patterns": [
        {
          "match": "(?<=[\\w\\]\\*>])\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.lucis" }
          }
        }
      ]
    },
    "function-call": {
      "comment": "Matches function and method calls: name(",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.lucis" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.lucis",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.comparison.lucis",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.lucis",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.lucis",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.arithmetic.lucis",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.lucis",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arrow.lucis",
          "match": "->"
        },
        {
          "name": "keyword.operator.null-coalescing.lucis",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.range.lucis",
          "match": "\\.\\.(=)?"
        },
        {
          "name": "keyword.operator.spread.lucis",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.ternary.lucis",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.accessor.scope.lucis",
          "match": "::"
        },
        {
          "name": "punctuation.accessor.dot.lucis",
          "match": "\\."
        },
        {
          "name": "punctuation.terminator.statement.lucis",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.lucis",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.lucis",
          "match": ","
        },
        {
          "name": "punctuation.definition.block.begin.lucis",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.end.lucis",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.bracket.begin.lucis",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.bracket.end.lucis",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.paren.begin.lucis",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.paren.end.lucis",
          "match": "\\)"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.lucis",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
